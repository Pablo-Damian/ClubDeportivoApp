<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ClubDeportivoApp">

        <!-- Pantalla de Login configurada como Entry Point (Punto de entrada) -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Registro de la pantalla del Menú Principal para habilitar la navegación mediante Intent -->
        <activity android:name=".MenuPrincipalActivity" />
        <activity android:name=".RegistrarSocioActivity" />
        <activity android:name=".AsignarActividadActivity" />
        <activity android:name=".ListaMorososActivity" />
        <activity android:name=".CobrarCuotaActivity" />
        <activity android:name=".FacturaCuotaActivity" />
        <activity android:name=".CarnetSocioActivity" />
        <activity android:name=".CobrarActividadActivity" />
        <activity android:name=".FacturaActividadActivity" />

    </application>

</manifest>