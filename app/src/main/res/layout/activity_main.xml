<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center"
    android:background="#F4A261"> <!-- Color naranja del "Club Deportivo" -->

    <!-- Logo/Escudo del "Club Deportivo" -->
    <ImageView
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:src="@drawable/escudo_logo"
        android:layout_marginBottom="48dp" />

    <!-- Etiqueta Usuario -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:text="Usuario"
        android:textColor="#333333"
        android:textSize="14sp" />

    <!-- Input Usuario (Con margen forzado) -->
    <EditText
        android:id="@+id/et_usuario"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="16dp"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:hint="Admin"
        android:inputType="textPersonName" />

    <!-- Etiqueta Contraseña -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:text="Contraseña"
        android:textColor="#333333"
        android:textSize="14sp" />

    <!-- Input Contraseña (Con margen forzado) -->
    <EditText
        android:id="@+id/et_contrasena"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="32dp"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:hint="************"
        android:inputType="textPassword" />

    <!-- Botón Ingresar -->
    <Button
        android:id="@+id/btn_ingresar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="#222D3E"
        android:textColor="#FFFFFF"
        android:text="Ingresar"
        android:textAllCaps="false"
        android:paddingHorizontal="48dp" />

</LinearLayout>