<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#84b6f4">

    <TextView
        android:id="@+id/tv_volver"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="← Volver al menú"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Factura digital cuota socio"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="32dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="24dp"
        android:layout_marginBottom="32dp">

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Comprobante Pago de Cuota" android:textStyle="bold" android:gravity="center" android:layout_marginBottom="16dp"/>

        <!-- IDs agregados para inyección de datos -->
        <TextView android:id="@+id/tv_socio" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Socio: "/>
        <TextView android:id="@+id/tv_monto" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Monto: $"/>
        <TextView android:id="@+id/tv_fecha" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Fecha: "/>
        <TextView android:id="@+id/tv_medio_pago" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Medio de pago: "/>
        <TextView android:id="@+id/tv_id_pago" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="ID de pago: "/>
    </LinearLayout>

    <Button
        android:id="@+id/btn_descargar_pdf"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Descargar como PDF"
        android:backgroundTint="#222D3E"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btn_ver_carnet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ver carnet de socio"
        android:backgroundTint="#222D3E"
        android:textColor="#FFFFFF"/>

</LinearLayout>