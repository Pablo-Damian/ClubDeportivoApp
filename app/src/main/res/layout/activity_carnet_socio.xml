<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#84b6f4">

    <TextView
        android:id="@+id/tv_volver"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="← Volver"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Carnet de socio"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="32dp" />

    <!-- Tarjeta del carnet -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="24dp"
        android:gravity="center_horizontal"
        android:layout_marginBottom="48dp">

        <!-- Avatar genérico -->
        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/avatar"
            android:layout_marginBottom="16dp"
            android:contentDescription="Foto del socio" />

        <TextView
            android:id="@+id/tv_nombre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#333333"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tv_dni"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DNI: "
            android:textColor="#555555"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tv_ingreso"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Socio desde: "
            android:textColor="#555555"
            android:layout_marginBottom="4dp"/>

        <!-- Se agregó el número de carnet que generamos aleatoriamente en la BD -->
        <TextView
            android:id="@+id/tv_nro_carnet"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nº de Carnet: "
            android:textColor="#555555"
            android:textStyle="bold"/>
    </LinearLayout>

    <Button
        android:id="@+id/btn_imprimir"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Imprimir carnet"
        android:backgroundTint="#222D3E"
        android:textColor="#FFFFFF" />

</LinearLayout>