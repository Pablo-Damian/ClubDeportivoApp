<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F4A261">

    <TextView
        android:id="@+id/tv_volver"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="← Volver"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Carnet de socio"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="32dp" />

    <!-- Tarjeta del carnet (Rectángulo blanco) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="24dp"
        android:gravity="center_horizontal"
        android:layout_marginBottom="48dp">

        <!-- Espacio para la foto -->
        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="#CCCCCC"
            android:layout_marginBottom="16dp"
            android:contentDescription="Foto del socio" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Juan Carlos"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#333333"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DNI xxxxxxxx"
            android:textColor="#555555"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Socio desde dd/mm/aaaa"
            android:textColor="#555555"/>
    </LinearLayout>

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Imprimir carnet"
        android:backgroundTint="#222D3E"
        android:textColor="#FFFFFF" />

</LinearLayout>